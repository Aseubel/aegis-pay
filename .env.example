MYSQL_PASSWORD=root
MYSQL_DATABASE=aegis_pay
MYSQL_MAX_IDLE_CONNS=10
MYSQL_MAX_OPEN_CONNS=100
MYSQL_CONN_MAX_LIFETIME=3600

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100

# ==================== 应用配置 ====================
APP_HOST=0.0.0.0
APP_PORT=8080
APP_MODE=debug

# ==================== 微信支付配置 ====================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=
WECHAT_CALLBACK_URL=

# ==================== 支付宝配置 ====================
ALIPAY_APP_ID=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_CALLBACK_URL=

# ==================== Milvus 配置 ====================
MILVUS_ENABLED=false
MILVUS_WRITE_ENABLED=false
MILVUS_ADDRESS=localhost:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_TOKEN=
MILVUS_DATABASE=
